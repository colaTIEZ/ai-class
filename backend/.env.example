# ai-class 环境配置模板
# 复制此文件为 .env 并填充实际值

# 应用配置
APP_NAME=ai-class
APP_VERSION=0.1.0
DEBUG=true

# 数据库配置
DATABASE_PATH=data/ai_class.db

# 外部 AI API 配置（后续 Epic 使用）
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=your-base-url-here
OPENAI_MODEL=your-text-generation-model
OPENAI_EMBEDDING_MODEL=your-embedding-model

# 服务器配置
HOST=0.0.0.0
PORT=8000

# CORS 配置（前端开发服务器地址）
CORS_ORIGINS=["http://localhost:5173"]